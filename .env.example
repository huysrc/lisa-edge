LISA_EDGE_HOSTNAME=lisa-edge-01
TZ=America/Los_Angeles
DATA_ROOT=/srv/lisa-edge
BACKUP_DEST=/srv/lisa-edge/backups
COMPOSE_PROJECT_NAME=lisa-edge

# Bind addresses. Prefer a VLAN_SVC IP instead of 0.0.0.0 in production.
MQTT_BIND_ADDR=0.0.0.0
UPTIME_KUMA_BIND_ADDR=0.0.0.0
ZIGBEE2MQTT_BIND_ADDR=0.0.0.0
NODE_RED_BIND_ADDR=0.0.0.0

# Service ports
MQTT_PORT=1883
MQTT_WS_PORT=9001
UPTIME_KUMA_PORT=3001
ZIGBEE2MQTT_PORT=8080
NODE_RED_PORT=1880
OTBR_WEB_PORT=8080
OTBR_REST_PORT=8081

# MQTT authentication. Change MQTT_PASSWORD before production use.
MQTT_USERNAME=lisa
MQTT_PASSWORD=change-this-password

# Thread Border Router
# Find this with: ls -l /dev/serial/by-id/
THREAD_RADIO_DEVICE=/dev/serial/by-id/YOUR_THREAD_RCP_RADIO
# Common UART URL for nRF52840/ZBT-2 RCP firmware.
THREAD_RADIO_URL=spinel+hdlc+uart:///dev/ttyThreadRCP?uart-baudrate=460800
# Backbone interface should be the service-facing NIC on VLAN_SVC or VLAN_CTRL path.
OTBR_BACKBONE_IF=enp1s0
OTBR_WEB_ENABLE=1

# Optional device paths
ZIGBEE_DONGLE=/dev/ttyACM0

# Optional compose profiles: otbr, homeassistant, zigbee2mqtt, node-red, vpn-tailscale
# Example: LISA_COMPOSE_PROFILES="otbr vpn-tailscale"
LISA_COMPOSE_PROFILES=

# Tailscale optional profile
TS_AUTHKEY=
TS_EXTRA_ARGS=
