###############################################################################
# LISA Edge - Environment Template
###############################################################################
# LISA Edge is a hardware-agnostic Linux infrastructure stack.
#
# It can run on ZimaBoard, Raspberry Pi, Intel NUC, mini PC, generic x86-64
# Linux server, or a VM. ZimaBoard 2 is only the reference platform.
###############################################################################
LISA_EDGE_HOSTNAME=lisa-edge-01
TZ=America/Los_Angeles
DATA_ROOT=/srv/lisa-edge
BACKUP_DEST=/srv/lisa-edge/backups
COMPOSE_PROJECT_NAME=lisa-edge

###############################################################################
# Network Bind Addresses
###############################################################################
# Prefer binding dashboards and services to a trusted service/admin IP instead
# of 0.0.0.0 in production.
###############################################################################
MQTT_BIND_ADDR=0.0.0.0
UPTIME_KUMA_BIND_ADDR=0.0.0.0
ZIGBEE2MQTT_BIND_ADDR=0.0.0.0
NODE_RED_BIND_ADDR=0.0.0.0
HEALTHCHECK_BIND_ADDR=127.0.0.1

###############################################################################
# Core Service Ports
###############################################################################
MQTT_PORT=1883
MQTT_WS_PORT=9001
UPTIME_KUMA_PORT=3001
ZIGBEE2MQTT_PORT=8080
NODE_RED_PORT=1880

###############################################################################
# MQTT
###############################################################################
# Change MQTT_PASSWORD before production use.
###############################################################################
MQTT_USERNAME=lisa
MQTT_PASSWORD=change-this-password

###############################################################################
# Optional Service Profiles
###############################################################################
# Space-separated list of optional compose services to enable.
#
# Current options:
#   otbr
#   vpn-tailscale
#   ha
#   zigbee2mqtt
#   node-red
#
# Example:
#   LISA_COMPOSE_SERVICES="otbr vpn-tailscale"
###############################################################################
LISA_COMPOSE_SERVICES=

# Host-level Thread preparation is only needed when running OTBR on this host.
# It installs Avahi and enables IPv6 forwarding.
LISA_ENABLE_THREAD_HOST_PREP=0

###############################################################################
# Thread Border Router (OTBR) - Optional
###############################################################################
# Enable only if this host will run OpenThread Border Router.
#
# Find YOUR_THREAD_RCP_RADIO with:
#   ls -l /dev/serial/by-id/
#
# Backbone interface should be the service-facing NIC on VLAN_SVC or VLAN_CTRL path.
###############################################################################
THREAD_RADIO_DEVICE=/dev/serial/by-id/YOUR_THREAD_RCP_RADIO
THREAD_RADIO_URL=spinel+hdlc+uart:///dev/ttyThreadRCP?uart-baudrate=460800
OTBR_BACKBONE_IF=enp1s0
OTBR_THREAD_IF=wpan0
OTBR_LOG_LEVEL=5
OTBR_DATASET_BACKUP_DIR=/srv/lisa-edge/backups/otbr
OTBR_DATASET_LATEST=/srv/lisa-edge/backups/otbr/latest.dataset.hex

# Automatically restore the most recent Thread dataset backup if OTBR starts
# with an empty configuration.
#
# Recommended: 1
OTBR_AUTO_RESTORE_DATASET=1

# Automatically create a brand-new Thread network if no dataset exists.
#
# WARNING:
# DO NOT enable this by default in production.
#
# If enabled, a fresh Thread dataset may be generated during deployment,
# causing all existing Matter-over-Thread devices to lose connectivity.
#
# Recommended:
#   Production = 0
#   Lab/Test   = 1
OTBR_AUTO_CREATE_NETWORK=0

###############################################################################
# Zigbee2MQTT - Optional
###############################################################################
ZIGBEE_DONGLE=/dev/ttyACM0

###############################################################################
# Tailscale / VPN - Optional
###############################################################################
TS_AUTHKEY=
TS_EXTRA_ARGS=
