#cloud-config
# LISA Edge Ubuntu autoinstall template.
#
# WARNING:
# This file can wipe disks. Review the storage section before use.
# Replace placeholders for hostname, SSH key, disk serial/model, and repo URL.

autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: us
  timezone: America/Los_Angeles

  identity:
    hostname: LISA-EDGE
    username: lisa
    # Temporary console password: ChangeMe123!
    # Replace this hash before production use.
    # SSH password login is disabled below.
    password: "$6$QWnRj98zWZbExza3$5LAYPxsnYH26jKNur5P3etIjgiHiLIIAj1qPFViSSn.Pbnir.lyXWnplCoaJ9YReVapx.vjawtD1GOjR6I1PD/"

  ssh:
    install-server: true
    allow-pw: false
    authorized-keys:
      # Replace with your public key.
      # Example:
      # - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAINjfuH5/II3sPBYVjLj7l8EltcYgrHkKD/8Dq31IQq8G
      - ssh-ed25519 REPLACE_WITH_YOUR_PUBLIC_KEY lisa-edge-admin

  packages:
    - ca-certificates
    - curl
    - htop
    - git

  storage:
    config:
      - type: disk
        id: install_disk
        match:
          # Replace with your target disk serial or model.
          # Find it with: lsblk -o NAME,MODEL,SERIAL,SIZE
          # Example: "serial: S2RANX0H6483662"
          serial: REPLACE_WITH_TARGET_DISK_SERIAL
        ptable: gpt
        wipe: superblock-recursive
        preserve: false
        grub_device: true

      - type: partition
        id: efi_partition
        device: install_disk
        size: 1G
        flag: boot
        wipe: superblock
        preserve: false

      - type: partition
        id: root_partition
        device: install_disk
        size: -1
        wipe: superblock
        preserve: false

      - type: format
        id: efi_format
        volume: efi_partition
        fstype: fat32

      - type: format
        id: root_format
        volume: root_partition
        fstype: ext4

      - type: mount
        id: efi_mount
        path: /boot/efi
        device: efi_format

      - type: mount
        id: root_mount
        path: /
        device: root_format

  user-data:
    disable_root: true
    package_update: true
    package_upgrade: false
    users:
      - default
    ssh_pwauth: false

  late-commands:
    - curtin in-target --target=/target -- git clone https://github.com/lisahq/lisa-edge.git /opt/lisa-edge
    - curtin in-target --target=/target -- bash /opt/lisa-edge/bootstrap/bootstrap.sh

  updates: security
  shutdown: reboot